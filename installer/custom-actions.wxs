<?xml version="1.0" encoding="UTF-8"?>
<!--
  DualView v0.2.3 - Custom Actions WiX

  CustomAction pour :
    1. Installation   : appel du script npm-build.ps1 (compile DualView)
    2. Desinstallation: appel du script uninstall-userdata.ps1 (dialog donnees)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>

    <!-- ── Binaires embarques dans le MSI ─────────────────────── -->
    <Binary Id="NpmBuildScript"       SourceFile="installer\npm-build.ps1" />
    <Binary Id="UninstallDataScript"  SourceFile="installer\uninstall-userdata.ps1" />

    <!-- ── Properties passees aux CustomActions ──────────────── -->
    <!-- Dossier source DualView (dossier d'extraction du MSI) -->
    <Property Id="DUALVIEW_SRC_DIR"  Value="[INSTALLFOLDER]" />

    <!-- ── CustomAction : desinstallation donnees utilisateur ─── -->
    <!--
      Appele AVANT la desinstallation des fichiers (InstallInitialize).
      Type 82 = deferred + impersonate (s'execute dans le contexte user).
      On utilise un script PowerShell extrait dans %TEMP%.
    -->
    <CustomAction
      Id="CA_UninstallUserData"
      BinaryRef="UninstallDataScript"
      ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Normal -File "[#UninstallDataScript]"'
      Execute="deferred"
      Impersonate="yes"
      Return="ignore" />
    <!--
      Return="ignore" : meme si l'utilisateur annule ou si une erreur
      survient, la desinstallation des fichiers continue.
    -->

    <!-- ── Sequence d'installation ────────────────────────────── -->
    <InstallExecuteSequence>
      <!-- Desinstallation : dialog avant suppression des fichiers -->
      <Custom Action="CA_UninstallUserData"
              After="InstallInitialize"
              Condition="REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

  </Fragment>

</Wix>
