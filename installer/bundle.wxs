<?xml version="1.0" encoding="UTF-8"?>
<!--
  DualView v0.2.3 - Burn Bootstrapper (WiX Toolset v4)

  Ce bootstrapper orchestrate l'installation en deux phases :
    1. Verifie Node.js >= 22 ; si absent, le telecharge et l'installe
    2. Lance npm install + electron-builder (via CustomAction PowerShell)
    3. Installe le MSI DualView compile

  Le fichier bundle.exe resultant est l'unique fichier a distribuer
  aux utilisateurs finaux.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle
    Name="DualView"
    Version="0.2.3"
    Manufacturer="DualView"
    UpgradeCode="F1E2D3C4-B5A6-9870-FEDC-BA9876543210"
    AboutUrl="https://github.com/dualview/dualview"
    IconSourceFile="..\assets\icon.ico"
    Compressed="yes">

    <!-- ── Theme UI Burn ──────────────────────────────────────── -->
    <bal:WixStandardBootstrapperApplication
      LicenseUrl=""
      Theme="hyperlinkLicense"
      LocalizationFile="installer\bundle-fr.wxl"
      LogoFile="..\assets\icon.ico"
      ShowVersion="yes" />

    <!-- ── Variables ─────────────────────────────────────────── -->
    <!-- Chemin Node.js detecte ou installe -->
    <Variable Name="NodePath"       Type="string" Value="" />
    <!-- Repertoire d'installation DualView -->
    <Variable Name="InstallFolder"  Type="string" Value="[ProgramFiles64Folder]DualView" />

    <!-- ── Detection Node.js >= 22 ───────────────────────────── -->
    <util:RegistrySearch
      Id="NodeVersionSearch"
      Root="HKLM"
      Key="SOFTWARE\Node.js"
      Value="Version"
      Variable="NodeInstalledVersion"
      Result="value"
      Win64="yes" />

    <util:DirectorySearch
      Id="NodeExeSearch"
      Variable="NodeExeFound"
      Path="[ProgramFiles64Folder]nodejs"
      Result="exists" />

    <!-- ── Chaine d'installation ──────────────────────────────── -->
    <Chain DisableRollback="no" ParallelCache="yes">

      <!--
        Package 1 : Node.js v22 LTS
        Installe uniquement si Node.js est absent ou version < 22.
        DetectCondition = vrai si deja present → skip.
        InstallCondition = faux si deja present → ne pas installer.
      -->
      <ExePackage
        Id="NodeJs"
        Name="Node.js v22 LTS"
        Description="Environnement d'execution JavaScript requis par DualView"
        DownloadUrl="https://nodejs.org/dist/latest-v22.x/node-v22.15.0-x64.msi"
        InstallCommand="/qn ADDLOCAL=ALL"
        RepairCommand="/qn REINSTALL=ALL REINSTALLMODE=vomus"
        UninstallCommand="/qn"
        DetectCondition="NodeExeFound"
        InstallCondition="NOT NodeExeFound"
        Vital="yes"
        Permanent="yes"
        Protocol="burn">
        <!--
          Permanent=yes : on ne desinstalle pas Node.js lors de la
          desinstallation de DualView (Node peut etre utilise ailleurs).
        -->
      </ExePackage>

      <!--
        Package 2 : Build DualView (npm install + electron-builder)
        ExePackage avec script PowerShell embarque.
        Uniquement execute a l'installation, pas a la desinstallation.
      -->
      <ExePackage
        Id="BuildDualView"
        Name="Compilation de DualView"
        Description="Installation des dependances et compilation"
        SourceFile="installer\build-runner.exe"
        InstallCommand=""
        DetectCondition="false"
        InstallCondition="NOT WixBundleAction = 5"
        Vital="yes"
        Permanent="yes"
        Protocol="burn" />
      <!--
        Note : build-runner.exe est un petit wrapper compile par
        build-installer.ps1 qui encapsule le script npm-build.ps1.
        WixBundleAction=5 correspond a Uninstall.
      -->

      <!--
        Package 3 : MSI DualView
        Le MSI principal installe les fichiers compiles d'Electron.
      -->
      <MsiPackage
        Id="DualViewMsi"
        Name="DualView"
        SourceFile="..\dist\DualView-0.2.3.msi"
        Vital="yes"
        ForcePerMachine="yes"
        DisplayInternalUI="no">
        <MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]" />
      </MsiPackage>

    </Chain>

  </Bundle>

</Wix>
